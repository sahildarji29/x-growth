generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  email               String?         @unique
  username            String          @unique
  password            String?
  credits             Int             @default(0)
  isGuest             Boolean         @default(false)
  emailVerified       Boolean         @default(false)
  isAdmin             Boolean         @default(false)
  followBonusClaimed  Boolean         @default(false)
  twitterId           String?         @unique
  twitterUsername     String?
  twitterAccessToken  String?
  twitterRefreshToken String?
  twitterTokenExpiry  DateTime?
  sessionCookie       String?
  authMethod          String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  cryptoPayments      CryptoPayment[]
  operations          Operation[]
  payments            Payment[]
  subscription        Subscription?

  @@index([email])
  @@index([username])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  tier                 String
  status               String
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  startDate            DateTime
  endDate              DateTime?
  cancelAt             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model Operation {
  id              String    @id @default(cuid())
  userId          String
  type            String
  status          String
  config          String?
  result          String?
  unfollowedCount Int?      @default(0)
  followedCount   Int?      @default(0)
  creditsUsed     Int       @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  error           String?
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  type            String
  amount          Float
  currency        String   @default("usd")
  stripePaymentId String?  @unique
  stripeInvoiceId String?
  status          String
  creditsAdded    Int?
  metadata        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model JobQueue {
  id          String    @id @default(cuid())
  type        String
  data        String
  status      String
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  processedAt DateTime?
  failedAt    DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, priority])
  @@index([createdAt])
}

model CryptoPayment {
  id          String    @id @default(cuid())
  paymentId   String    @unique
  userId      String?
  email       String?
  package     String
  credits     Int
  amountUSD   Float
  currency    String
  amount      Float
  status      String    @default("pending")
  txHash      String?
  provider    String?
  expiresAt   DateTime
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id])

  @@index([paymentId])
  @@index([userId])
  @@index([status])
  @@index([email])
}

model License {
  id              String    @id @default(cuid())
  key             String    @unique
  tier            String
  customerName    String?
  customerEmail   String?
  companyName     String?
  maxUsers        Int       @default(500)
  maxInstances    Int       @default(1)
  whiteLabel      Boolean   @default(false)
  customDomain    Boolean   @default(false)
  apiAccess       Boolean   @default(false)
  activations     Int       @default(0)
  lastActivatedAt DateTime?
  instanceIds     String?
  status          String    @default("active")
  expiresAt       DateTime?
  paymentId       String?
  amountPaid      Float?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([key])
  @@index([customerEmail])
  @@index([status])
}

model AccountSnapshot {
  id        String   @id @default(cuid())
  username  String
  type      String   @default("full")
  data      String
  createdAt DateTime @default(now())

  @@index([username, type])
  @@index([createdAt])
}

model FollowerSnapshot {
  id         String   @id @default(cuid())
  userId     String
  username   String
  followers  String
  totalCount Int
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([username, createdAt])
}

model FollowerChange {
  id            String    @id @default(cuid())
  userId        String
  type          String
  username      String
  name          String?
  avatarUrl     String?
  detectedAt    DateTime  @default(now())
  followedSince DateTime?

  @@index([userId, detectedAt])
  @@index([userId, type])
}

model UnfollowerSchedule {
  id         String    @id @default(cuid())
  userId     String    @unique
  interval   String
  active     Boolean   @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  webhookUrl String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([active, nextRunAt])
}
