# =============================================================================
# XActions Growth Bot (xeepy) — Environment Configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in YOUR values, then run:
#     python growth_bot.py
#
# Every teammate gets their own .env + their own persona files. Nothing here is
# shared between accounts. NEVER commit your real .env (it holds secrets/session).
# =============================================================================


# =============================================================================
# 1. IDENTITY & AUTH  (per user — required)
# =============================================================================

# Your X / Twitter username, without the @. Used to skip your OWN posts.
XEEPY_USERNAME=

# Your X / Twitter password (only used for the first Playwright login).
XEEPY_PASSWORD=

# Saved browser session (created on first login; avoids logging in every run).
XEEPY_SESSION_FILE=./data/session.json


# =============================================================================
# 2. AI PROVIDER — Groq  (required for comment + post generation)
# =============================================================================

# Free Groq API key — https://console.groq.com  (format: gsk_...)
GROQ_API_KEY=

# Model used to generate comments/posts. Fallback chain is automatic on rate
# limits: llama-3.3-70b-versatile -> llama-3.1-8b-instant -> gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Per-request timeout (seconds) for the Groq API.
GROQ_TIMEOUT_S=30


# =============================================================================
# 3. PERSONA  (per user — THIS is what makes replies sound like YOU)
# -----------------------------------------------------------------------------
# Two ways to set each persona (checked in this order):
#   a) inline env var (PERSONA_COMMENT / PERSONA_POST) — quick but awkward
#   b) a path to a .md file (recommended) — edit it like a normal document
# If neither is set, a built-in default persona is used.
# =============================================================================

# Path to your COMMENT persona (voice, audience, positioning, skip rules).
PERSONA_COMMENT_FILE=./config/persona_comment.md

# Path to your ORIGINAL-POST persona (for standalone tweets, not replies).
PERSONA_POST_FILE=./config/persona_post.md

# Angles the bot rotates through when writing original posts (one per line).
POST_ANGLES_FILE=./config/post_angles.txt

# Optional inline overrides (take priority over the files above). Usually leave blank.
# PERSONA_COMMENT="You are ..."
# PERSONA_POST="You are ..."
# POST_ANGLES=first angle|second angle|third angle


# =============================================================================
# 4. TARGETING  (per user — WHO/WHAT you engage with)
# =============================================================================

# Search keywords the bot rotates through to find tweets to engage with.
TARGET_KEYWORDS=AI automation,LLM,coding agents,agentic AI,developer tools,open source AI

# Optional: @handles whose audience you want to target (comma-separated, no @).
# TARGET_ACCOUNTS=

# --- Relevance scoring -------------------------------------------------------
# Before commenting, each tweet is scored from these keyword tiers. A comment is
# only generated when the score >= COMMENT_SCORE_THRESHOLD. Tune to YOUR niche.
COMMENT_SCORE_THRESHOLD=6

# +10 each: your core topics (a match here alone clears the threshold).
SCORE_HIGH=laravel,livewire,filament,php,ai agent,agentic,claude code,cursor,agent orchestration,mcp server,open source,developer tool,framework,sdk

# +6 each: adjacent / audience topics (a single match just clears the threshold).
SCORE_MEDIUM=saas,startup,founder,cto,engineering leadership,llm,gpt,claude,anthropic,openai,rag,developer experience,typescript,python,django,devops,ci/cd,docker,kubernetes

# -10 each: hard "never engage" topics (sinks the score below the threshold).
SCORE_NEGATIVE=politics,election,giveaway,crypto,bitcoin,nft,blockchain,motivation,hustle culture,celebrity

# Optional: change the point values themselves (defaults shown).
# SCORE_HIGH_POINTS=10
# SCORE_MEDIUM_POINTS=6
# SCORE_NEGATIVE_POINTS=10


# =============================================================================
# 5. ENGAGEMENT VOLUME  (per-run targets — the bot stops once all are hit)
# =============================================================================

MAX_COMMENTS=500
MAX_LIKES=300
MAX_FOLLOWS=150


# =============================================================================
# 6. ORIGINAL POSTS  (randomized daily count — keep low to protect reputation)
# -----------------------------------------------------------------------------
# The bot posts a RANDOM number of original tweets each day, between MIN and MAX
# (with an occasional quieter day). SAFETY_MAX_POSTS_DAY is the hard ceiling and
# always wins, so raise it too if you raise the range.
# =============================================================================

POSTS_PER_DAY_MIN=2
POSTS_PER_DAY_MAX=3
SAFETY_MAX_POSTS_DAY=3


# =============================================================================
# 7. PACING  (human-like delays in seconds — lower is riskier)
# =============================================================================

COMMENT_DELAY_MIN=90
COMMENT_DELAY_MAX=150
LIKE_DELAY_MIN=3
LIKE_DELAY_MAX=8
FOLLOW_DELAY_MIN=5
FOLLOW_DELAY_MAX=12

# Active hours are informational for this bot (it runs 24/7 until stopped) but
# are used to spread original posts across the day.
BOT_ACTIVE_START=9
BOT_ACTIVE_END=22


# =============================================================================
# 8. SAFETY — daily hard caps  (enforced + persisted across restarts)
# =============================================================================

SAFETY_MAX_LIKES_DAY=300
SAFETY_MAX_COMMENTS_DAY=500
SAFETY_MAX_FOLLOWS_DAY=150
SAFETY_MAX_UNFOLLOWS_DAY=50
SAFETY_MAX_RETWEETS_DAY=20

# Warn once this fraction of a daily cap is reached (0.0–1.0).
SAFETY_WARNING_THRESHOLD=0.8

# Pause ALL actions for this long (seconds) after any 429/403 from X.
SAFETY_COOLDOWN_SECONDS=7200

# Persistence paths (per user — keep separate if running multiple accounts).
SAFETY_DB_PATH=./data/xeepy_safety.db
SAFETY_LOCK_FILE=/tmp/xeepy.lock


# =============================================================================
# 9. BROWSER / STORAGE / LOGGING
# =============================================================================

# Run the browser headless (true) or visible (false).
BOT_HEADLESS=true

# Optional proxy for the browser.
# XEEPY_PROXY=socks5://127.0.0.1:1080

XEEPY_DATA_DIR=./data
XEEPY_CONFIG_DIR=./config
XEEPY_LOG_LEVEL=INFO
