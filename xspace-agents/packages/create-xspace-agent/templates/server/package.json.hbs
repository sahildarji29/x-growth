{
  "name": "{{projectName}}",
  "version": "0.1.0",
  "private": true,
  "description": "X Space agent server with admin panel powered by xspace-agent",
{{#if typescript}}
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "dev": "tsc --watch"
  },
{{else}}
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js"
  },
{{/if}}
  "dependencies": {
    "xspace-agent": "^0.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.5"
  }{{#if typescript}},
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }{{/if}}
}
