{
  "name": "xspace-agent",
  "version": "0.2.0",
  "description": "TypeScript SDK for AI agents in X/Twitter Spaces — join, listen, speak, and respond with LLM-powered bots",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./cicd": {
      "types": "./dist/cicd/index.d.ts",
      "import": "./dist/cicd/index.js",
      "require": "./dist/cicd/index.js"
    },
    "./dist/tenant": {
      "types": "./dist/tenant/index.d.ts",
      "import": "./dist/tenant/index.js",
      "require": "./dist/tenant/index.js"
    },
    "./dist/voice": {
      "types": "./dist/voice/index.d.ts",
      "import": "./dist/voice/index.js",
      "require": "./dist/voice/index.js"
    },
    "./dist/events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "require": "./dist/events/index.js"
    },
    "./dist/browser/selector-engine": {
      "types": "./dist/browser/selector-engine.d.ts",
      "import": "./dist/browser/selector-engine.js",
      "require": "./dist/browser/selector-engine.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc",
    "db:migrate": "ts-node src/db/migrate.ts migrate",
    "db:seed": "ts-node src/db/migrate.ts seed"
  },
  "keywords": [
    "twitter",
    "x",
    "spaces",
    "ai",
    "agent",
    "bot",
    "voice",
    "puppeteer",
    "llm",
    "openai",
    "claude",
    "groq",
    "tts",
    "stt",
    "speech"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@node-saml/passport-saml": "^5.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.45.1",
    "form-data": "^4.0.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "openid-client": "^5.7.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.0"
  }
}
