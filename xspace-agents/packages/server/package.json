    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
