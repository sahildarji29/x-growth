{
  "name": "@xspace/server",
  "version": "0.1.0",
  "description": "Admin panel and WebSocket API server for xspace-agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
