{
  "name": "xspace-agent-monorepo",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "files": [
    "dist/",
    "public/",
    "x-spaces/"
  ],
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer"
    ]
  },
  "scripts": {
    "build": "turbo build",
    "build:legacy": "npx tsc && npx vite build",
    "build:server": "npx tsc",
    "build:client": "npx vite build",
    "dev": "npx tsx watch packages/server/src/index.ts",
    "dev:legacy": "npx tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "start:legacy": "node server.js",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix",
    "typecheck": "npx tsc --noEmit && npx tsc -p tsconfig.client.json --noEmit",
    "test": "cd packages/core && npx --no-install vitest run",
    "format": "npx prettier --write \"src/**/*.ts\"",
    "format:check": "npx prettier --check \"src/**/*.ts\"",
    "docker:build": "docker build -t xspace-agent .",
    "docker:run": "docker run --env-file .env -p 3000:3000 --shm-size=2gb xspace-agent",
    "docker:up": "docker compose up -d",
    "docker:up:monitoring": "docker compose --profile with-monitoring up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f agent",
    "security": "npm audit --audit-level=high",
    "security:audit": "npm audit --audit-level=high",
    "db:migrate": "pnpm -F xspace-agent run db:migrate",
    "db:seed": "pnpm -F xspace-agent run db:seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "artillery": "^2.0.30",
    "artillery-engine-socketio-v3": "^1.2.0",
    "eslint": "^9.39.4",
    "nodemon": "^3.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.2",
    "vitest": "^4.1.2"
  }
}
