  </footer>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 40);
    });

    const pc = document.getElementById('particles');
    for (let i = 0; i < 25; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.left = Math.random() * 100 + '%';
      p.style.animationDuration = (18 + Math.random() * 25) + 's';
      p.style.animationDelay = (Math.random() * 20) + 's';
      p.style.width = (2 + Math.random() * 2) + 'px';
      p.style.height = p.style.width;
      pc.appendChild(p);
    }

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.feature-mockup, .benefit-card, .testimonial-card, .testimonial-rating').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(30px)';
      el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      obs.observe(el);
    });
  </script>

  <!-- XSpace Chat Widget -->
  <script src="/xspace-widget.umd.js"
          data-server-url=""
          data-agent-id="agent-1"
          data-theme="dark"
          data-position="bottom-right">
  </script>
</body>
</html>
