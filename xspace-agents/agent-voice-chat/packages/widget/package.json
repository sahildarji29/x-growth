{
  "name": "@agent-voice-chat/widget",
  "version": "1.0.0",
  "description": "Embeddable AI voice chat widget — add voice AI to any website with a single script tag",
  "main": "dist/agent-voice-chat.min.js",
  "module": "dist/agent-voice-chat.esm.js",
  "types": "dist/agent-voice-chat.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "terser": "^5.46.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0"
  },
  "peerDependencies": {
    "socket.io-client": "^4.7.0"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    }
  },
  "license": "UNLICENSED",
  "keywords": [
    "voice-chat",
    "ai",
    "widget",
    "embeddable",
    "webrtc",
    "socket.io"
  ]
}
